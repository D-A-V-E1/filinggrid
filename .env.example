# Copy to .env in project root and backend/.env
# Frontend reads NEXT_PUBLIC_* at build time

# ── App URLs ──────────────────────────────────────────────
# Frontend origin — used in Stripe redirects (backend: APP_URL or FRONTEND_URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Backend API — browser uses /api/backend proxy in production (see next.config.mjs)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Supabase (Auth) ───────────────────────────────────────
# Required for sign-in, magic links, and Stripe checkout. Anonymous compare works
# without these — leave TODO placeholders (or omit) for local dev without auth.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (sb_publishable_...) or legacy anon key (eyJ...) — @supabase/ssr 2.x accepts both
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# Backend: SUPABASE_URL (JWKS ES256) and/or legacy SUPABASE_JWT_SECRET (HS256) in backend/.env

# ── Stripe ────────────────────────────────────────────────
# Test keys locally (sk_test_..., pk_test_...). Use live keys only in production hosting.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PROFESSIONAL=price_...
# Alias supported by backend: STRIPE_PRICE_ID_PRO=price_...
# Optional — Checkout is server-side; not required for MVP self-serve flow
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://filinggrid:filinggrid@localhost:5432/filinggrid

# ── SEC EDGAR ─────────────────────────────────────────────
SEC_USER_AGENT=PeerDisclosures/1.0 (your-email@yourcompany.com)
FILING_CACHE_ENABLED=true
FILING_CACHE_DIR=.cache/filings

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
# Backend Stripe success/cancel/portal URLs (must match browser origin)
APP_URL=http://localhost:3000
# Alias: FRONTEND_URL=http://localhost:3000

# ── Dev/test tier toggle (local only — never in production) ─
# Backend gates all overrides behind ALLOW_DEV_TIER_TOGGLE=true
ALLOW_DEV_TIER_TOGGLE=true
DEV_PRO_TIER=false
# Frontend: show in-app Free/Professional toggle in compare header (also on in npm run dev)
# NEXT_PUBLIC_ALLOW_DEV_TIER_TOGGLE=true
# Optional legacy: force tier on every API call without using the UI toggle
# NEXT_PUBLIC_DEV_TIER=professional
