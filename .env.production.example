# PeerDisclosures — production environment template
# Copy values into your hosting secret managers (Vercel, Railway, Render, etc.).
# NEVER commit real secrets. Do NOT copy this file to .env in git.
#
# See docs/PRODUCTION_DEPLOY.md for step-by-step dashboard setup.

# ═══════════════════════════════════════════════════════════
# VERCEL (frontend) — set in Project → Settings → Environment Variables
# Apply to: Production (and Preview only if you use staging)
# ═══════════════════════════════════════════════════════════

NEXT_PUBLIC_APP_URL=https://peerdisclosures.com
# Used by next.config.mjs rewrites (/api/backend/* → API host) at build time
NEXT_PUBLIC_API_URL=https://api.peerdisclosures.com

NEXT_PUBLIC_SUPABASE_URL=https://cbqiqbcqzvfozewqzqnl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...or_eyJ...

# Optional — Checkout is server-side today; safe to omit for MVP
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── PRODUCTION: DO NOT SET THESE ──────────────────────────
# NEXT_PUBLIC_ALLOW_DEV_TIER_TOGGLE=true
# NEXT_PUBLIC_DEV_TIER=professional

# ═══════════════════════════════════════════════════════════
# API HOST (Railway / Render / Fly.io / VPS) — backend secrets
# ═══════════════════════════════════════════════════════════

# Managed PostgreSQL (Neon, Supabase DB, RDS, Railway Postgres, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/filinggrid?sslmode=require

# Supabase auth — JWKS preferred (set URL; no shared secret required for ES256/RSA)
SUPABASE_URL=https://cbqiqbcqzvfozewqzqnl.supabase.co
# Optional HS256 fallback during JWT key rotation:
# SUPABASE_JWT_SECRET=your-legacy-jwt-secret

# Stripe LIVE mode
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...from_live_webhook_endpoint
STRIPE_PRICE_PROFESSIONAL=price_...live_price_id

# Must match browser origin (Stripe redirects + CORS)
APP_URL=https://peerdisclosures.com
CORS_ORIGINS=https://peerdisclosures.com
# If you serve www without redirect, add: ,https://www.peerdisclosures.com

# SEC EDGAR fair-access policy — real contact email required
SEC_USER_AGENT=PeerDisclosures/1.0 (support@peerdisclosures.com)

# Filing cache (ephemeral disk on PaaS — use persistent volume if available)
FILING_CACHE_ENABLED=true
FILING_CACHE_DIR=.cache/filings

# ── PRODUCTION: dev overrides OFF ───────────────────────
ALLOW_DEV_TIER_TOGGLE=false
DEV_PRO_TIER=false

# ═══════════════════════════════════════════════════════════
# OPTIONAL — error monitoring (not wired in code yet; see PRODUCTION_DEPLOY.md)
# ═══════════════════════════════════════════════════════════

# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
