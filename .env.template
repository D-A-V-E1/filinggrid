# FilingGrid local environment template
# Copy to .env (project root) AND backend/.env — fill every TODO value.
# NEVER commit .env files with real secrets.

# ── App URLs ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Supabase (Auth) — from supabase.com → Project Settings → API ──
NEXT_PUBLIC_SUPABASE_URL=TODO_https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TODO_eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=TODO_your-jwt-secret-from-supabase-dashboard

# ── Stripe (test mode) — from dashboard.stripe.com/test ──
STRIPE_SECRET_KEY=TODO_sk_test_...
STRIPE_WEBHOOK_SECRET=TODO_whsec_...from_stripe_listen
STRIPE_PRICE_PROFESSIONAL=TODO_price_...
# Optional — Checkout is server-side today
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=TODO_pk_test_...

# ── Database — docker compose postgres default ────────────
DATABASE_URL=postgresql://filinggrid:filinggrid@localhost:5432/filinggrid

# ── SEC EDGAR ─────────────────────────────────────────────
SEC_USER_AGENT=FilingGrid/1.0 (TODO_your-email@yourcompany.com)
FILING_CACHE_ENABLED=true
FILING_CACHE_DIR=.cache/filings

# ── CORS / Stripe redirects ───────────────────────────────
CORS_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000

# ── Dev tier toggle (local only — omit in production) ─────
ALLOW_DEV_TIER_TOGGLE=true
DEV_PRO_TIER=false
